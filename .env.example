# Compose
BACKEND_PORT=8000
FRONTEND_PORT=5173
FRONTEND_VITE_API_BASE_URL=http://localhost:8000/api

# Backend
RAG_COPILOT_SECRET_KEY=replace-with-a-secure-random-string
RAG_COPILOT_ACCESS_TOKEN_EXPIRE_MINUTES=480
RAG_COPILOT_DATABASE_URL=sqlite:////app/data/rag_copilot.db
RAG_COPILOT_VECTOR_STORE_DIR_OVERRIDE=/app/data/faiss
RAG_COPILOT_CHUNK_SIZE=800
RAG_COPILOT_CHUNK_OVERLAP=120
RAG_COPILOT_EMBEDDING_DIMENSION=384
RAG_COPILOT_DEFAULT_TOP_K=5
RAG_COPILOT_OLLAMA_BASE_URL=http://ollama:11434
RAG_COPILOT_OLLAMA_TIMEOUT_SECONDS=60
RAG_COPILOT_OLLAMA_QWEN_MODEL=qwen2.5:7b
RAG_COPILOT_OLLAMA_DEEPSEEK_MODEL=deepseek-r1:7b
RAG_COPILOT_OLLAMA_LLAMA_MODEL=llama3.1:8b
RAG_COPILOT_INITIAL_ADMIN_USERNAME=admin
RAG_COPILOT_INITIAL_ADMIN_PASSWORD=change-this-password
RAG_COPILOT_INITIAL_ADMIN_EMAIL=admin@example.local
